# Environment Configuration Template
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3000

# Database Configuration (PostgreSQL)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=corporate_learning_db
DB_SQLJS_PATH=.data/dev.sqlite

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug

# API Configuration
API_PREFIX=api
API_VERSION=v1

# Email Configuration (Console-based for Phase 1)
EMAIL_FROM=noreply@corporatelearning.local
EMAIL_ADMIN=admin@corporatelearning.local
