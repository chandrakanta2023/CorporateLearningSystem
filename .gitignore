# Corporate Learning System - Root .gitignore

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment Variables
.env
.env.local
.env.*.local

# Build Outputs
dist/
build/
*.tsbuildinfo

# Logs
logs/
*.log

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# IDE Files (Personal Preferences)
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# Keep VS Code Extensions Recommendations
!.vscode/extensions.json

# Database Files
*.sqlite
*.sqlite3
*.db

# Coverage Reports
coverage/
*.lcov
.nyc_output/

# Temporary Files
*.tmp
*.temp
.cache/

# Package Manager Lock Files (Optional - Keep for consistency)
# Uncomment if you want to ignore lock files:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# PostgreSQL
*.sql.log
*.sql.tmp

# Certificates & Keys
*.pem
*.key
*.cert

# Backup Files
*.bak
*.backup
*.old
